# AgentCore Gateway MCP endpoint (get this from deploy_lambda_servers.sh output)
AGENTCORE_GATEWAY_URL=https://your-gateway-id.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp
AWS_REGION=us-east-1

# Planning mode: sop_first (check for pre-built SOPs first) | authoritative (always custom plan)
PLANNER_MODE=sop_first

# Bedrock model for the planner's reasoning calls
PLANNER_MODEL_ID=us.anthropic.claude-sonnet-5
