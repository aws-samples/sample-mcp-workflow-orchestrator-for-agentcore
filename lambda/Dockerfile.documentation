FROM public.ecr.aws/lambda/python:3.12

# Install the AWS Documentation MCP server and Lambda handler
RUN pip install --no-cache-dir --upgrade \
    awslabs.mcp-lambda-handler \
    awslabs.aws-documentation-mcp-server

# Set the MCP server command that the handler will wrap
ENV MCP_SERVER_COMMAND="awslabs.aws-documentation-mcp-server"
ENV LOG_LEVEL="INFO"
ENV MCP_TIMEOUT="90"

# Copy the generic handler
COPY handler.py ${LAMBDA_TASK_ROOT}/

CMD ["handler.lambda_handler"]
